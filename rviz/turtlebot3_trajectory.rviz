Panels:
  - Class: rviz_common/Displays
    Help Height: 78
    Name: Displays
    Property Tree Widget:
      Expanded:
        - /Global Options1
        - /Odometry1
        - /Smooth Path1
        - /Actual Path1
        - /Trajectory1
        - /Waypoints Marker1
      Splitter Ratio: 0.5
    Tree Height: 549
  - Class: rviz_common/Selection
    Name: Selection
  - Class: rviz_common/Tool Properties
    Expanded:
      - /2D Goal Pose1
      - /Publish Point1
    Name: Tool Properties
    Splitter Ratio: 0.5
  - Class: rviz_common/Views
    Expanded:
      - /Current View1
    Name: Views
    Splitter Ratio: 0.5
Visualization Manager:
  Class: ""
  Displays:
    - Alpha: 0.5
      Cell Size: 1
      Class: rviz_default_plugins/Grid
      Color: 160; 160; 164
      Enabled: true
      Name: Grid
    - Class: rviz_default_plugins/Odometry
      Covariance:
        Orientation:
          Color: 255; 255; 127
          Radius: 0.1
      Enabled: true
      Keep: 100
      Name: Odometry
      Position Tolerance: 0.1
      Shape:
        Alpha: 1
        Axes Length: 0.5
        Axes Radius: 0.05
        Radius: 0.1
      Topic: /odom
      Value: true
    - Class: rviz_default_plugins/Path
      Color: 0; 255; 0
      Enabled: true
      Line Style: Lines
      Name: Smooth Path
      Pose Style: None
      Topic: /smooth_path
      Value: true
    - Class: rviz_default_plugins/Path
      Color: 255; 165; 0
      Enabled: true
      Line Style: Lines
      Name: Actual Path
      Pose Style: None
      Topic: /actual_path
      Value: true
    - Class: rviz_default_plugins/Path
      Color: 0; 0; 255
      Enabled: true
      Line Style: Lines
      Name: Trajectory
      Pose Style: None
      Topic: /ref_trajectory
      Value: true
    - Class: rviz_default_plugins/MarkerArray
      Enabled: true
      Name: Waypoints Marker
      Namespaces:
        waypoints: true
      Topic: /waypoints_marker
      Value: true
  Enabled: true
  Global Options:
    Background Color: 48; 48; 48
    Fixed Frame: odom
    Frame Rate: 30
  Name: root
  Tools:
    - Class: rviz_default_plugins/Interact
      Hide Inactive Objects: true
    - Class: rviz_default_plugins/MoveCamera
    - Class: rviz_default_plugins/Select
  Value: true
  Views:
    Current:
      Class: rviz_default_plugins/TopDownOrtho
      Name: Current View
      Scale: 50
      Target Frame: <Fixed Frame>
      X: 1.5
      Y: 0.0
    Saved: ~
